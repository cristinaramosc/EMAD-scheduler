+def _quarter_suffix(subject):
+    """Retorna '1q' o '2q' si el nom de l'assignatura acaba amb aquest sufix
+    (independent de majúscules/minúscules i espais), o None en cas contrari."""
+    text = (subject or "").strip().lower()
+    if text.endswith("1q"):
+        return "1q"
+    if text.endswith("2q"):
+        return "2q"
+    return None
+
+
+def is_valid_quarter_pair(first_subject, second_subject):
+    """Dues assignatures poden compartir la mateixa cel·la horària només si
+    una acaba en '1Q' i l'altra en '2Q' (primer i segon quadrimestre)."""
+    first_quarter = _quarter_suffix(first_subject)
+    second_quarter = _quarter_suffix(second_subject)
+    return first_quarter is not None and second_quarter is not None and first_quarter != second_quarter
+
